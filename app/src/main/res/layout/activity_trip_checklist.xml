<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    android:fillViewport="true"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="36dp"
            android:paddingEnd="18dp">

            <ImageView
                android:id="@+id/buttonChecklistBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="뒤로가기"
                android:padding="6dp"
                android:src="@drawable/ic_tripline_back"
                app:tint="@color/schedule_minimal_text" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/buttonChecklistEdit"
                style="@style/TriplineText.ActionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="편집"
                android:textColor="@color/schedule_minimal_blue" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="30dp"
            android:text="상하이 여행 · 3박4일"
            android:textColor="@color/schedule_minimal_subtle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="8dp"
            android:text="여행 준비\n체크리스트"
            android:textColor="@color/schedule_minimal_text"
            android:textSize="24sp"
            android:fontFamily="@font/pretendardbold"
            android:lineSpacingExtra="2dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="36dp"
            android:background="@color/tripline_surface_neutral" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <TextView
                style="@style/TriplineText.SectionTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="필수 준비물"
                android:textColor="@color/schedule_minimal_text" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:rotation="180"
                android:src="@drawable/ic_schedule_chevron_down"
                app:tint="@color/tripline_stroke_neutral" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/tripline_stroke_neutral" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_tripline_circle_outline"
                app:tint="@color/tripline_stroke_neutral" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="여권"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="16sp"
                    android:fontFamily="@font/pretendardbold" />

                <TextView
                    style="@style/TriplineText.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="여권사본, 여권사진 여분"
                    android:textColor="@color/tripline_stroke_neutral" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_tripline_circle_outline"
                app:tint="@color/tripline_stroke_neutral" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="환전"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="16sp"
                    android:fontFamily="@font/pretendardbold" />

                <TextView
                    style="@style/TriplineText.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="현지 통화 준비, 환전 영수증 보관"
                    android:textColor="@color/tripline_stroke_neutral" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="90dp"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingTop="12dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_tripline_circle_outline"
                app:tint="@color/tripline_stroke_neutral" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="항공권티켓"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="16sp"
                    android:fontFamily="@font/pretendardbold" />

                <TextView
                    style="@style/TriplineText.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="항공편명 기록, E-티켓 출력"
                    android:textColor="@color/tripline_stroke_neutral" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>

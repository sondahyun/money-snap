<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    android:fillViewport="true"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="뒤로가기"
                android:padding="6dp"
                android:src="@drawable/ic_tripline_back"
                app:tint="@color/schedule_minimal_text" />

            <TextView
                style="@style/TriplineText.NavTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="날씨"
                android:textColor="@color/schedule_minimal_text" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                style="@style/TriplineText.Badge"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="상하이"
                android:textColor="@color/schedule_minimal_text" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="상하이 여행 · 2.15 - 2.18"
            android:textColor="@color/schedule_minimal_subtle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/pretendardbold"
            android:lineSpacingExtra="2dp"
            android:text="여행 기간 중\n상하이 날씨"
            android:textColor="@color/schedule_minimal_text"
            android:textSize="24sp" />

        <TextView
            style="@style/TriplineText.BodyCompact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="여행 일정과 함께 볼 수 있도록 일별 날씨와 시차를 정리했어요."
            android:textColor="@color/schedule_minimal_subtle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.15"
                    android:textColor="@color/schedule_minimal_subtle" />

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginTop="10dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_weather_sun" />

                <TextView
                    style="@style/TriplineText.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="6° / 20°"
                    android:textColor="@color/schedule_minimal_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.16"
                    android:textColor="@color/schedule_minimal_subtle" />

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginTop="10dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_weather_cloud" />

                <TextView
                    style="@style/TriplineText.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="3° / 9°"
                    android:textColor="@color/schedule_minimal_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.17"
                    android:textColor="@color/schedule_minimal_subtle" />

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginTop="10dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_weather_rain" />

                <TextView
                    style="@style/TriplineText.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="2° / 8°"
                    android:textColor="@color/schedule_minimal_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.18"
                    android:textColor="@color/schedule_minimal_subtle" />

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginTop="10dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_weather_sun" />

                <TextView
                    style="@style/TriplineText.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="2° / 12°"
                    android:textColor="@color/schedule_minimal_text" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/TriplineText.Meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="제공 OpenWeather"
            android:textColor="@color/tripline_text_hint" />

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="28dp"
            android:background="@color/tripline_surface_neutral" />

        <TextView
            style="@style/TriplineText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="시차는 서울보다"
            android:textColor="@color/schedule_minimal_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/pretendardbold"
            android:text="1시간 느림"
            android:textColor="@color/schedule_minimal_blue"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026.04.22 · 화"
                    android:textColor="@color/schedule_minimal_subtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/pretendardbold"
                    android:text="02:39"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="28sp" />

                <TextView
                    style="@style/TriplineText.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/tripline_surface_neutral"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="서울"
                    android:textColor="@color/tripline_text_secondary" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="72dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="@color/tripline_stroke_neutral" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026.04.22 · 화"
                    android:textColor="@color/schedule_minimal_subtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/pretendardbold"
                    android:text="01:39"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="28sp" />

                <TextView
                    style="@style/TriplineText.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/tripline_surface_neutral"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="상하이"
                    android:textColor="@color/tripline_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_marginTop="28dp"
            android:background="@color/tripline_surface_neutral" />

        <TextView
            style="@style/TriplineText.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="챙기면 좋아요"
            android:textColor="@color/schedule_minimal_text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="top"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="@color/schedule_minimal_blue" />

            <TextView
                style="@style/TriplineText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="일교차가 커서 가벼운 겉옷을 챙기는 편이 좋아요."
                android:textColor="@color/schedule_minimal_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="@color/tripline_marker_amber" />

            <TextView
                style="@style/TriplineText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="맑은 날에는 선글라스나 선크림을 준비해두면 편해요."
                android:textColor="@color/schedule_minimal_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="@color/tripline_marker_teal" />

            <TextView
                style="@style/TriplineText.Body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="비 예보가 있으면 접이식 우산이나 방수 파우치를 같이 챙겨보세요."
                android:textColor="@color/schedule_minimal_text" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>

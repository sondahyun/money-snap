<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/schedule_minimal_blue_soft"
                    android:fontFamily="@font/pretendardsemibold"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:text="TRIPLINE"
                    android:textColor="@color/schedule_minimal_blue"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/pretendardbold"
                    android:text="여행을 실행하는 순간까지\n흐름을 놓치지 않게"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="24sp"
                    android:lineSpacingExtra="3dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/pretendardregular"
                    android:text="Tripline은 일정, 동선, 장소, 경비를 같은 맥락에서 보게 해주는 여행 실행 앱입니다."
                    android:textColor="@color/schedule_minimal_subtle"
                    android:textSize="14sp"
                    android:lineSpacingExtra="1dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="@color/schedule_minimal_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/schedule_minimal_line"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendardbold"
                        android:text="로그인"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="19sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/pretendardregular"
                        android:text="이메일 계정으로 내 여행 보관함에 들어갑니다."
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:fontFamily="@font/pretendardsemibold"
                        android:text="이메일"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="13sp" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_tripline_input"
                        android:fontFamily="@font/pretendardmedium"
                        android:hint="tripline@example.com"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:textColor="@color/schedule_minimal_text"
                        android:textColorHint="@color/schedule_minimal_subtle"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/pretendardsemibold"
                        android:text="비밀번호"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="13sp" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_tripline_input"
                        android:fontFamily="@font/pretendardmedium"
                        android:hint="비밀번호를 입력하세요"
                        android:inputType="textPassword"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:textColor="@color/schedule_minimal_text"
                        android:textColorHint="@color/schedule_minimal_subtle"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/pretendardmedium"
                        android:text="비밀번호를 잊으셨나요?"
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/bg_tripline_action"
                        android:backgroundTint="@color/schedule_minimal_blue"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="로그인"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_tripline_secondary_action"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="가입 없이 둘러보기"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/pretendardregular"
                    android:text="처음이신가요?"
                    android:textColor="@color/schedule_minimal_subtle"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="회원가입"
                    android:textColor="@color/schedule_minimal_blue"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

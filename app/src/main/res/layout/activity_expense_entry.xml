<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    android:fillViewport="true"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="18dp">

            <ImageView
                android:id="@+id/buttonExpenseEntryBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="닫기"
                android:src="@drawable/ic_tripline_close"
                android:tint="@color/schedule_minimal_text" />

            <TextView
                style="@style/TriplineText.NavTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:text="비용 추가"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="20sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/buttonExpenseEntryMore"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:contentDescription="더보기"
                android:padding="2dp"
                android:src="@drawable/ic_tripline_more_horizontal"
                android:tint="@color/schedule_minimal_text" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/tripline_stroke_neutral" />

        <LinearLayout
            android:id="@+id/buttonExpenseCurrency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="30dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TriplineText.CardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KRW(원)"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="18sp" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_schedule_chevron_down"
                android:tint="@color/schedule_minimal_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="26dp"
            android:layout_marginEnd="20dp"
            android:orientation="horizontal"
            android:paddingBottom="26dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="금액입력"
                android:textColor="@color/tripline_text_hint"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="*"
                android:textColor="#FF5B64"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:background="@color/tripline_surface_neutral" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="28dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:id="@+id/buttonExpenseDateSelect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TriplineText.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="날짜선택"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="*"
                        android:textColor="#FF5B64"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TriplineText.ScreenTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="day 2 2.16/월"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="21sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_schedule_chevron_down"
                        android:tint="@color/schedule_minimal_text" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/tripline_stroke_neutral" />
            </LinearLayout>

            <Space
                android:layout_width="24dp"
                android:layout_height="1dp" />

            <LinearLayout
                android:id="@+id/buttonExpensePaymentSelect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TriplineText.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="결제수단"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="*"
                        android:textColor="#FF5B64"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TriplineText.ScreenTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="현금"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="21sp" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_schedule_chevron_down"
                        android:tint="@color/schedule_minimal_text" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/tripline_stroke_neutral" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="34dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/TriplineText.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="항목명"
                    android:textColor="@color/schedule_minimal_subtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:text="*"
                    android:textColor="#FF5B64"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                style="@style/TriplineText.ScreenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="남상만두 예원 점"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="21sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/tripline_stroke_neutral" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="34dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/TriplineText.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="카테고리"
                    android:textColor="@color/schedule_minimal_subtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:text="*"
                    android:textColor="#FF5B64"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_home"
                        android:tint="#D9DCE3" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="숙소"
                        android:textColor="#C5CBD5" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_tripline_route"
                        android:tint="#D9DCE3" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="항공"
                        android:textColor="#C5CBD5" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_calendar"
                        android:tint="#D9DCE3" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="교통"
                        android:textColor="#C5CBD5" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_tripline_book"
                        android:tint="#D9DCE3" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="관광"
                        android:textColor="#C5CBD5" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:src="@drawable/ic_tripline_food"
                        android:tint="@color/schedule_minimal_blue" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="식비"
                        android:textColor="@color/schedule_minimal_blue"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_money"
                        android:tint="#D9DCE3" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="쇼핑"
                        android:textColor="#C5CBD5" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttonExpenseCategoryMore"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_tripline_icon_button_neutral"
                        android:padding="9dp"
                        android:src="@drawable/ic_tripline_more_horizontal"
                        android:tint="#BFC6D0" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:text="기타"
                        android:textColor="#C5CBD5" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="34dp"
            android:paddingEnd="20dp">

            <TextView
                style="@style/TriplineText.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="장소(선택)"
                android:textColor="@color/schedule_minimal_subtle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/TriplineText.ScreenTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="남상만두 예원 점"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="21sp" />

                <ImageView
                    android:id="@+id/buttonExpensePlaceClear"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_tripline_icon_button_neutral"
                    android:padding="8dp"
                    android:src="@drawable/ic_tripline_close"
                    android:tint="#C7CDD6" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/tripline_stroke_neutral" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="34dp"
            android:paddingEnd="20dp">

            <TextView
                style="@style/TriplineText.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="메모 및 사진 (선택)"
                android:textColor="@color/schedule_minimal_subtle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="메모를 입력하세요."
                android:textColor="@color/tripline_text_hint"
                android:textSize="20sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="18dp"
                android:background="@color/tripline_stroke_neutral" />

            <FrameLayout
                android:id="@+id/buttonExpenseEntryPhotoAdd"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_tripline_secondary_action_neutral">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="+"
                    android:textColor="@color/tripline_text_hint"
                    android:textSize="30sp" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/buttonExpenseEntrySaveBottom"
            style="@style/TriplineText.Button"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="34dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_tripline_secondary_action_neutral"
            android:gravity="center"
            android:text="완료"
            android:textColor="@color/tripline_text_hint"
            android:textSize="18sp" />
    </LinearLayout>
</ScrollView>

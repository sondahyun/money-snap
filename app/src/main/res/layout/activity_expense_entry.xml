<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="16dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/pretendardbold"
                android:text="경비 입력"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="18sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            app:cardBackgroundColor="@color/schedule_minimal_surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/schedule_minimal_line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tripline_action"
                        android:backgroundTint="@color/schedule_minimal_blue"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="장소 기반"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tripline_secondary_action"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="카테고리 기반"
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="금액"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="13sp" />

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_tripline_input"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center_vertical"
                    android:hint="0"
                    android:inputType="number"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/schedule_minimal_text"
                    android:textColorHint="@color/schedule_minimal_subtle"
                    android:textSize="21sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="날짜"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_tripline_input"
                    android:fontFamily="@font/pretendardmedium"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="2026.2.15"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="장소 또는 상위 카테고리"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_tripline_input"
                    android:fontFamily="@font/pretendardmedium"
                    android:gravity="center_vertical"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="와이탄"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="14sp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/schedule_minimal_blue_soft"
                            android:fontFamily="@font/pretendardsemibold"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="8dp"
                            android:text="와이탄"
                            android:textColor="@color/schedule_minimal_blue"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_tripline_secondary_action"
                            android:fontFamily="@font/pretendardsemibold"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="8dp"
                            android:text="환전"
                            android:textColor="@color/schedule_minimal_subtle"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_tripline_secondary_action"
                            android:fontFamily="@font/pretendardsemibold"
                            android:paddingStart="12dp"
                            android:paddingTop="8dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="8dp"
                            android:text="유심"
                            android:textColor="@color/schedule_minimal_subtle"
                            android:textSize="12sp" />
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="결제수단"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tripline_secondary_action"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="현금"
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tripline_action"
                        android:backgroundTint="@color/schedule_minimal_blue"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="카드"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_tripline_secondary_action"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="기타"
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/pretendardsemibold"
                    android:text="메모"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="13sp" />

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_tripline_input"
                    android:fontFamily="@font/pretendardmedium"
                    android:gravity="top"
                    android:hint="예: 부모님 간식, 택시비, 입장권"
                    android:padding="18dp"
                    android:textColor="@color/schedule_minimal_text"
                    android:textColorHint="@color/schedule_minimal_subtle"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_tripline_action"
                    android:backgroundTint="@color/schedule_minimal_blue"
                    android:fontFamily="@font/pretendardsemibold"
                    android:gravity="center"
                    android:text="저장"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>

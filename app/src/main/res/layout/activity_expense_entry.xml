<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="16dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_schedule_icon_button"
                android:contentDescription="뒤로가기"
                android:padding="8dp"
                android:src="@drawable/ic_tripline_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                style="@style/TriplineText.NavTitle"
                android:text="경비 입력"
                android:textColor="@color/schedule_minimal_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_action"
                android:backgroundTint="@color/schedule_minimal_blue"
                android:gravity="center"
                style="@style/TriplineText.Button"
                android:text="장소 기반"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                style="@style/TriplineText.Button"
                android:text="카테고리 기반"
                android:textColor="@color/schedule_minimal_subtle" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            style="@style/TriplineText.Label"
            android:text="금액"
            android:textColor="@color/schedule_minimal_subtle" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tripline_input"
            android:fontFamily="@font/pretendardbold"
            android:gravity="center_vertical"
            android:hint="0"
            android:inputType="number"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/schedule_minimal_text"
            android:textColorHint="@color/schedule_minimal_subtle"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            style="@style/TriplineText.Label"
            android:text="날짜"
            android:textColor="@color/schedule_minimal_subtle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tripline_input"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            style="@style/TriplineText.Body"
            android:text="2026.2.15"
            android:textColor="@color/schedule_minimal_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            style="@style/TriplineText.Label"
            android:text="장소 또는 상위 카테고리"
            android:textColor="@color/schedule_minimal_subtle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tripline_input"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            style="@style/TriplineText.Body"
            android:text="와이탄"
            android:textColor="@color/schedule_minimal_text" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/schedule_minimal_blue_soft"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    style="@style/TriplineText.Badge"
                    android:text="와이탄"
                    android:textColor="@color/schedule_minimal_blue" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_tripline_secondary_action"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    style="@style/TriplineText.Badge"
                    android:text="환전"
                    android:textColor="@color/schedule_minimal_subtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_tripline_secondary_action"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    style="@style/TriplineText.Badge"
                    android:text="유심"
                    android:textColor="@color/schedule_minimal_subtle" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            style="@style/TriplineText.Label"
            android:text="결제수단"
            android:textColor="@color/schedule_minimal_subtle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                style="@style/TriplineText.Button"
                android:text="현금"
                android:textColor="@color/schedule_minimal_subtle" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_action"
                android:backgroundTint="@color/schedule_minimal_blue"
                android:gravity="center"
                style="@style/TriplineText.Button"
                android:text="카드"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                style="@style/TriplineText.Button"
                android:text="기타"
                android:textColor="@color/schedule_minimal_subtle" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            style="@style/TriplineText.Label"
            android:text="메모"
            android:textColor="@color/schedule_minimal_subtle" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_tripline_input"
            android:fontFamily="@font/pretendardmedium"
            android:gravity="top"
            android:hint="예: 부모님 간식, 택시비, 입장권"
            android:padding="16dp"
            android:textColor="@color/schedule_minimal_text"
            android:textColorHint="@color/schedule_minimal_subtle"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_tripline_action"
            android:backgroundTint="@color/schedule_minimal_blue"
            android:gravity="center"
            style="@style/TriplineText.Button"
            android:text="저장"
            android:textColor="@color/white" />
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp"
    tools:ignore="HardcodedText">

    <ProgressBar
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:indeterminateTint="@color/schedule_minimal_blue" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/pretendardbold"
        android:text="여행 흐름을 다시 정리하고 있어요"
        android:textColor="@color/schedule_minimal_text"
        android:textSize="17sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/pretendardregular"
        android:gravity="center"
        android:text="장소, 동선, 경비 정보를 불러오는 중입니다."
        android:textColor="@color/schedule_minimal_subtle"
        android:textSize="13sp" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="14dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/buttonBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_schedule_icon_button">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_schedule_back"
                        app:tint="@color/schedule_minimal_text" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textTripTitleTop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TriplineText.NavTitle"
                        android:text="상하이 여행"
                        android:textColor="@color/schedule_minimal_text" />

                    <TextView
                        android:id="@+id/textTripMetaTop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        style="@style/TriplineText.Meta"
                        android:text="2.15 - 2.18 · 3박 4일"
                        android:textColor="@color/schedule_minimal_subtle" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/buttonShare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_schedule_icon_button">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_schedule_share"
                        app:tint="@color/schedule_minimal_text" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/buttonMore"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_schedule_icon_button">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_schedule_more"
                        app:tint="@color/schedule_minimal_text" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/scheduleEmptySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TriplineText.ScreenTitle"
                    android:text="먼저 여행을 만들어 주세요"
                    android:textColor="@color/schedule_minimal_text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    style="@style/TriplineText.Body"
                    android:text="여행을 만든 뒤 해당 여행 안에서 장소를 추가하고 day별 일정을 짤 수 있어요."
                    android:textColor="@color/schedule_minimal_subtle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonScheduleEmptyCreateTrip"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        style="@style/TriplineText.Button"
                        android:text="새 여행 만들기"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        app:backgroundTint="@color/schedule_minimal_blue"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonScheduleEmptyOpenLocker"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        style="@style/TriplineText.Button"
                        android:text="보관함 보기"
                        android:textAllCaps="false"
                        android:textColor="@color/schedule_minimal_text"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="18dp"
                        app:strokeColor="@color/schedule_minimal_line"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/scheduleContentSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mapPreviewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_schedule_map_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="156dp">

                        <View
                            android:layout_width="240dp"
                            android:layout_height="4dp"
                            android:alpha="0.55"
                            android:background="@color/schedule_minimal_blue"
                            android:rotation="-14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintHorizontal_bias="0.48"
                            app:layout_constraintVertical_bias="0.48" />

                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/tripline_marker_blue"
                            android:fontFamily="@font/pretendardbold"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintHorizontal_bias="0.11"
                            app:layout_constraintVertical_bias="0.70" />

                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/tripline_marker_teal"
                            android:fontFamily="@font/pretendardbold"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintHorizontal_bias="0.67"
                            app:layout_constraintVertical_bias="0.46" />

                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/tripline_marker_coral"
                            android:fontFamily="@font/pretendardbold"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintHorizontal_bias="0.90"
                            app:layout_constraintVertical_bias="0.18" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_schedule_distance_chip"
                                android:paddingStart="10dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="8dp"
                                style="@style/TriplineText.Meta"
                                android:text="도보 11분"
                                android:textColor="@color/schedule_minimal_text" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_schedule_distance_chip"
                                android:paddingStart="10dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="8dp"
                                style="@style/TriplineText.Meta"
                                android:text="차량 4분"
                                android:textColor="@color/schedule_minimal_text" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_schedule_distance_chip"
                                android:paddingStart="10dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="8dp"
                                style="@style/TriplineText.Meta"
                                android:text="1.3km"
                                android:textColor="@color/schedule_minimal_text" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="54dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="@color/schedule_minimal_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/TriplineText.DayTitle"
                                    android:text="day 1"
                                    android:textColor="@color/schedule_minimal_text" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    style="@style/TriplineText.Body"
                                    android:text="2.15/일"
                                    android:textColor="@color/schedule_minimal_subtle" />

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_marginStart="6dp"
                                    android:src="@drawable/ic_schedule_chevron_down"
                                    app:tint="@color/schedule_minimal_subtle" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/buttonEditDay1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TriplineText.ActionLabel"
                            android:text="편집"
                            android:textColor="@color/schedule_minimal_blue" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_tripline_pill"
                                android:backgroundTint="@color/tripline_marker_violet"
                                android:fontFamily="@font/pretendardbold"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="@color/white"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="2dp"
                                android:layout_height="82dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_schedule_timeline_line" />

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_tripline_pill"
                                android:backgroundTint="@color/tripline_marker_amber"
                                android:fontFamily="@font/pretendardbold"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="@color/white"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardPlaceAirport"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:cardBackgroundColor="@color/schedule_minimal_surface"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/schedule_minimal_line"
                                app:strokeWidth="1dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="16dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        style="@style/TriplineText.NavTitle"
                                        android:text="상하이 홍차오 국제공항"
                                        android:textColor="@color/schedule_minimal_text" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        style="@style/TriplineText.BodyCompact"
                                        android:text="관광명소 · 예약가능"
                                        android:textColor="@color/schedule_minimal_subtle" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_schedule_distance_chip"
                                android:paddingStart="12dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="8dp"
                                style="@style/TriplineText.Meta"
                                android:text="14.6km · 차량 28분 · 도보 2시간 52분"
                                android:textColor="@color/schedule_minimal_text" />

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardPlaceHotel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                app:cardBackgroundColor="@color/schedule_minimal_surface"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/schedule_minimal_line"
                                app:strokeWidth="1dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="16dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        style="@style/TriplineText.NavTitle"
                                        android:text="캄파닐레 호텔 상하이 번드"
                                        android:textColor="@color/schedule_minimal_text" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        style="@style/TriplineText.BodyCompact"
                                        android:text="3성급 · 인민 광장 주변"
                                        android:textColor="@color/schedule_minimal_subtle" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonAddPlaceDay1"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            style="@style/TriplineText.Button"
                            android:text="장소 추가"
                            android:textAllCaps="false"
                            android:textColor="@color/schedule_minimal_text"
                            app:backgroundTint="@color/white"
                            app:cornerRadius="18dp"
                            app:strokeColor="@color/schedule_minimal_line"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonAddMemoDay1"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            style="@style/TriplineText.Button"
                            android:text="메모 추가"
                            android:textAllCaps="false"
                            android:textColor="@color/schedule_minimal_text"
                            app:backgroundTint="@color/white"
                            app:cornerRadius="18dp"
                            app:icon="@drawable/ic_schedule_note"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:iconTint="@color/schedule_minimal_text"
                            app:strokeColor="@color/schedule_minimal_line"
                            app:strokeWidth="1dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/TriplineText.DayTitle"
                                    android:text="day 2"
                                    android:textColor="@color/schedule_minimal_text" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    style="@style/TriplineText.Body"
                                    android:text="2.16/월"
                                    android:textColor="@color/schedule_minimal_subtle" />
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_tripline_pill"
                                android:backgroundTint="@color/tripline_marker_blue"
                                android:fontFamily="@font/pretendardbold"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="@color/white"
                                android:textSize="12sp" />

                            <View
                                android:layout_width="2dp"
                                android:layout_height="82dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_schedule_timeline_line" />

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_tripline_pill"
                                android:backgroundTint="@color/tripline_marker_teal"
                                android:fontFamily="@font/pretendardbold"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="@color/white"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/cardPlaceWaitan"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:cardBackgroundColor="@color/schedule_minimal_surface"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/schedule_minimal_line"
                                app:strokeWidth="1dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:padding="16dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/bg_tripline_tag"
                                        android:paddingStart="10dp"
                                        android:paddingTop="7dp"
                                        android:paddingEnd="10dp"
                                        android:paddingBottom="7dp"
                                        style="@style/TriplineText.Badge"
                                        android:text="관광명소"
                                        android:textColor="@color/schedule_minimal_blue" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="12dp"
                                        style="@style/TriplineText.NavTitle"
                                        android:text="와이탄"
                                        android:textColor="@color/schedule_minimal_text" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="6dp"
                                        style="@style/TriplineText.BodyCompact"
                                        android:text="관광명소 · 인민 광장 주변 · 예약가능"
                                        android:textColor="@color/schedule_minimal_subtle" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_schedule_distance_chip"
                                    android:paddingStart="10dp"
                                    android:paddingTop="8dp"
                                    android:paddingEnd="10dp"
                                    android:paddingBottom="8dp"
                                    style="@style/TriplineText.Meta"
                                    android:text="401m"
                                    android:textColor="@color/schedule_minimal_text" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"

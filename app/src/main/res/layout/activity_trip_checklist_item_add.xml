<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    android:fillViewport="true"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="22dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="뒤로가기"
                android:padding="6dp"
                android:src="@drawable/ic_tripline_back"
                android:tint="@color/schedule_minimal_text" />

            <TextView
                style="@style/TriplineText.NavTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="아이템 추가"
                android:textColor="@color/schedule_minimal_text" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                style="@style/TriplineText.ActionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="저장"
                android:textColor="@color/schedule_minimal_blue" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="체크리스트에 새 준비물을 추가해요"
            android:textColor="@color/schedule_minimal_subtle" />

        <TextView
            style="@style/TriplineText.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="아이템 이름"
            android:textColor="@color/schedule_minimal_subtle" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_tripline_input"
            android:fontFamily="@font/pretendardmedium"
            android:gravity="center_vertical"
            android:hint="예: 여행자 보험"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/schedule_minimal_text"
            android:textColorHint="@color/schedule_minimal_subtle"
            android:textSize="16sp" />

        <TextView
            style="@style/TriplineText.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="메모"
            android:textColor="@color/schedule_minimal_subtle" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_tripline_input"
            android:fontFamily="@font/pretendardregular"
            android:gravity="top"
            android:hint="예: 빠르고 간편하게 가입하기"
            android:padding="16dp"
            android:textColor="@color/schedule_minimal_text"
            android:textColorHint="@color/schedule_minimal_subtle"
            android:textSize="14sp" />

        <TextView
            style="@style/TriplineText.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="카테고리"
            android:textColor="@color/schedule_minimal_subtle" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    style="@style/TriplineText.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/schedule_minimal_blue"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="필수 준비물"
                    android:textColor="@color/white" />

                <TextView
                    style="@style/TriplineText.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_tripline_secondary_action"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="기본 짐싸기"
                    android:textColor="@color/schedule_minimal_subtle" />
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            style="@style/TriplineText.Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="속성"
            android:textColor="@color/schedule_minimal_subtle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                style="@style/TriplineText.Badge"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="필수"
                android:textColor="@color/schedule_minimal_subtle" />

            <TextView
                style="@style/TriplineText.Badge"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="부모님 공용"
                android:textColor="@color/schedule_minimal_subtle" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.Button"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_tripline_action"
            android:backgroundTint="@color/schedule_minimal_blue"
            android:gravity="center"
            android:text="아이템 저장"
            android:textColor="@color/white" />
    </LinearLayout>
</ScrollView>

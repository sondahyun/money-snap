<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp"
    tools:ignore="HardcodedText">

    <TextView
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:background="@drawable/bg_tripline_pill"
        android:backgroundTint="@color/tripline_coral_soft"
        android:fontFamily="@font/pretendardbold"
        android:gravity="center"
        android:text="!"
        android:textColor="@color/tripline_coral"
        android:textSize="20sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/pretendardbold"
        android:text="불러오기에 실패했어요"
        android:textColor="@color/schedule_minimal_text"
        android:textSize="17sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="네트워크 상태를 확인하고 다시 시도해 주세요."
        android:textColor="@color/schedule_minimal_subtle"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_tripline_action"
        android:backgroundTint="@color/schedule_minimal_blue"
        android:fontFamily="@font/pretendardsemibold"
        android:gravity="center"
        android:minWidth="140dp"
        android:text="다시 시도"
        android:textColor="@color/white"
        android:textSize="14sp" />
</LinearLayout>

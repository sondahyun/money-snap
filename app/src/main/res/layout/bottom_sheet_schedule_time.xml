<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/schedule_minimal_surface"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="10dp"
    android:paddingEnd="24dp"
    android:paddingBottom="28dp"
    tools:ignore="HardcodedText">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_tripline_pill"
        android:backgroundTint="@color/schedule_minimal_line" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        style="@style/TriplineText.ScreenTitle"
        android:text="시간"
        android:textColor="@color/schedule_minimal_text" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        style="@style/TriplineText.Body"
        android:text="이 일정 아이템의 시간을 기록해 둘 수 있어요."
        android:textColor="@color/schedule_minimal_subtle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_tripline_input"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_tripline_clock"
            android:tint="@color/schedule_minimal_subtle" />

        <TextView
            android:id="@+id/textScheduleTimeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            style="@style/TriplineText.CardTitle"
            android:text="18:00"
            android:textColor="@color/schedule_minimal_text" />
    </LinearLayout>

    <TextView
        android:id="@+id/buttonScheduleTimeSave"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_tripline_action"
        android:backgroundTint="@color/schedule_minimal_blue"
        android:gravity="center"
        style="@style/TriplineText.Button"
        android:text="시간 저장"
        android:textColor="@color/white" />
</LinearLayout>

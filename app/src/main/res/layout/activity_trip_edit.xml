<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="←"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/pretendardbold"
                    android:text="여행 정보 수정"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/schedule_minimal_blue_soft"
                    android:fontFamily="@font/pretendardsemibold"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:text="진행 예정"
                    android:textColor="@color/schedule_minimal_blue"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/pretendardmedium"
                    android:text="여행 기본 정보를 정리하면 보관함에서도 더 찾기 쉬워집니다."
                    android:textColor="@color/schedule_minimal_subtle"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/pretendardbold"
                android:lineSpacingExtra="4dp"
                android:text="여행의 기본 정보와\n표시 방식을 다듬어볼게요"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="26sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/schedule_minimal_surface"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/schedule_minimal_line"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendardsemibold"
                        android:text="여행 제목"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="13sp" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_tripline_input"
                        android:fontFamily="@font/pretendardmedium"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="상하이 여행"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/pretendardsemibold"
                        android:text="국가 / 도시"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <EditText
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_input"
                            android:fontFamily="@font/pretendardmedium"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="중국"
                            android:textColor="@color/schedule_minimal_text"
                            android:textSize="14sp" />

                        <EditText
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_input"
                            android:fontFamily="@font/pretendardmedium"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="상하이"
                            android:textColor="@color/schedule_minimal_text"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/pretendardsemibold"
                        android:text="여행 기간"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_input"
                            android:fontFamily="@font/pretendardmedium"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="2026.2.15"
                            android:textColor="@color/schedule_minimal_text"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_input"
                            android:fontFamily="@font/pretendardmedium"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="2026.2.18"
                            android:textColor="@color/schedule_minimal_text"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/pretendardsemibold"
                        android:text="총 예산 / 기준 통화"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <EditText
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_weight="1.4"
                            android:background="@drawable/bg_tripline_input"
                            android:fontFamily="@font/pretendardmedium"
                            android:inputType="number"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="1200000"
                            android:textColor="@color/schedule_minimal_text"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="54dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_input"
                            android:fontFamily="@font/pretendardmedium"
                            android:gravity="center_vertical"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="KRW"
                            android:textColor="@color/schedule_minimal_text"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/pretendardsemibold"
                        android:text="여행 한 줄 소개"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="13sp" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="96dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_tripline_input"
                        android:fontFamily="@font/pretendardmedium"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:padding="18dp"
                        android:text="부모님과 함께, 동선은 여유롭게 잡고 대표 관광지는 꼭 가는 일정"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_tripline_action"
                        android:backgroundTint="@color/schedule_minimal_blue"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="수정 내용 저장"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_secondary_action"
                            android:fontFamily="@font/pretendardsemibold"
                            android:gravity="center"
                            android:text="여행 보관"
                            android:textColor="@color/schedule_minimal_text"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_secondary_action"
                            android:backgroundTint="@color/tripline_coral_soft"
                            android:fontFamily="@font/pretendardsemibold"
                            android:gravity="center"
                            android:text="여행 삭제"
                            android:textColor="@color/tripline_coral"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

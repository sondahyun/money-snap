<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/schedule_minimal_surface"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="10dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp"
    tools:ignore="HardcodedText">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_tripline_pill"
        android:backgroundTint="@color/schedule_minimal_line" />

    <LinearLayout
        android:id="@+id/buttonPlaceSheetDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textPlaceSheetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TriplineText.ScreenTitle"
                android:text="남상만두 예원 점"
                android:textColor="@color/schedule_minimal_text" />

            <TextView
                android:id="@+id/textPlaceSheetMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                style="@style/TriplineText.Body"
                android:text="음식점 · 인민 광장 주변 · 예약가능"
                android:textColor="@color/schedule_minimal_subtle" />

            <TextView
                android:id="@+id/textPlaceSheetHours"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                style="@style/TriplineText.Body"
                android:text="영업시간 08:30 - 21:00"
                android:textColor="@color/schedule_minimal_blue" />
        </LinearLayout>

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_tripline_chevron_right"
            android:tint="@color/schedule_minimal_subtle" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/buttonPlaceTimeAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_tripline_clock"
            android:tint="@color/schedule_minimal_subtle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            style="@style/TriplineText.CardTitle"
            android:text="시간 추가"
            android:textColor="@color/schedule_minimal_subtle" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/buttonPlaceMemoAdd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_schedule_note"
            android:tint="@color/schedule_minimal_subtle" />

        <TextView
            android:id="@+id/textPlaceMemoAdd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            style="@style/TriplineText.CardTitle"
            android:text="메모 추가"
            android:textColor="@color/schedule_minimal_subtle" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonPlaceExpenseAdd"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            style="@style/TriplineText.Button"
            android:text="비용 추가"
            android:textAllCaps="false"
            android:textColor="@color/schedule_minimal_text"
            app:backgroundTint="@color/white"
            app:cornerRadius="18dp"
            app:strokeColor="@color/schedule_minimal_line"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonPlaceDetailBottom"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            style="@style/TriplineText.Button"
            android:text="리뷰쓰기"
            android:textAllCaps="false"
            android:textColor="@color/schedule_minimal_text"
            app:backgroundTint="@color/white"
            app:cornerRadius="18dp"
            app:strokeColor="@color/schedule_minimal_line"
            app:strokeWidth="1dp" />
    </LinearLayout>
</LinearLayout>

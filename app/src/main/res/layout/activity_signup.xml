<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="20dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="뒤로가기"
                android:padding="6dp"
                android:src="@drawable/ic_schedule_back"
                app:tint="@color/schedule_minimal_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="56dp"
                style="@style/TriplineText.ScreenTitle"
                android:text="나만의 여행 보관함을\nTripline에 만들어요"
                android:textColor="@color/schedule_minimal_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                style="@style/TriplineText.Body"
                android:text="가입 후에는 여행 계획, 장소, 경비를 계정 기준으로 안전하게 저장할 수 있습니다."
                android:textColor="@color/schedule_minimal_subtle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TriplineText.Body"
                        android:text="닉네임"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/pretendardbold"
                        android:hint="앱에서 사용할 이름"
                        android:paddingTop="0dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/schedule_minimal_text"
                        android:textColorHint="@color/tripline_text_hint"
                        android:textSize="18sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tripline_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="34dp"
                        style="@style/TriplineText.Body"
                        android:text="이메일"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/pretendardbold"
                        android:hint="tripline@example.com"
                        android:paddingTop="0dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/schedule_minimal_text"
                        android:textColorHint="@color/tripline_text_hint"
                        android:textSize="18sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tripline_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="34dp"
                        style="@style/TriplineText.Body"
                        android:text="비밀번호"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/pretendardbold"
                        android:hint="8자 이상 입력"
                        android:inputType="textPassword"
                        android:paddingTop="0dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/schedule_minimal_text"
                        android:textColorHint="@color/tripline_text_hint"
                        android:textSize="18sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tripline_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="34dp"
                        style="@style/TriplineText.Body"
                        android:text="비밀번호 확인"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/pretendardbold"
                        android:hint="비밀번호를 다시 입력"
                        android:inputType="textPassword"
                        android:paddingTop="0dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/schedule_minimal_text"
                        android:textColorHint="@color/tripline_text_hint"
                        android:textSize="18sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tripline_stroke" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="38dp"
                        android:background="@drawable/bg_tripline_secondary_action_neutral"
                        android:gravity="center"
                        style="@style/TriplineText.Button"
                        android:text="회원가입"
                        android:textColor="@color/schedule_minimal_text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TriplineText.BodyCompact"
                        android:text="이미 계정이 있나요?"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        style="@style/TriplineText.ActionLabel"
                        android:text="로그인"
                        android:textColor="@color/schedule_minimal_blue" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

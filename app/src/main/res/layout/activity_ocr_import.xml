<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="10dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_schedule_icon_button"
                android:contentDescription="뒤로가기"
                android:padding="8dp"
                android:src="@drawable/ic_tripline_back" />

            <TextView
                style="@style/TriplineText.NavTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="OCR 가져오기"
                android:textColor="@color/schedule_minimal_text" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                style="@style/TriplineText.ActionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="취소"
                android:textColor="@color/schedule_minimal_subtle" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.ScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="읽은 일정 중 넣을 항목만 고를게요"
            android:textColor="@color/schedule_minimal_text" />

        <TextView
            style="@style/TriplineText.BodyCompact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="항공권, 숙소, 패키지 일정표에서 읽은 항목을 먼저 확인한 뒤 일정 편집으로 넘깁니다."
            android:textColor="@color/schedule_minimal_subtle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                style="@style/TriplineText.Button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_action"
                android:backgroundTint="@color/schedule_minimal_blue"
                android:gravity="center"
                android:text="사진 찍기"
                android:textColor="@color/white" />

            <TextView
                style="@style/TriplineText.Button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:text="앨범에서 가져오기"
                android:textColor="@color/schedule_minimal_text" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="인식된 일정"
            android:textColor="@color/schedule_minimal_text" />

        <TextView
            style="@style/TriplineText.BodyCompact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="확실한 항목만 체크하고, 애매한 항목은 여기서 수정하거나 제외할 수 있어요."
            android:textColor="@color/schedule_minimal_subtle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TriplineText.Badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="@color/schedule_minimal_blue_soft"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="인식 3개"
                android:textColor="@color/schedule_minimal_blue" />

            <TextView
                style="@style/TriplineText.Badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="검토 필요 1개"
                android:textColor="@color/schedule_minimal_subtle" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="10dp">

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.15 12:00 김포공항 출발"
                    android:textColor="@color/schedule_minimal_text" />

                <TextView
                    style="@style/TriplineText.BodyCompact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="대한항공 KE895 · 상하이 홍차오 국제공항 도착"
                    android:textColor="@color/schedule_minimal_subtle" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/schedule_minimal_line" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.15 캄파닐레 호텔 상하이 번드"
                    android:textColor="@color/schedule_minimal_text" />

                <TextView
                    style="@style/TriplineText.BodyCompact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="체크인 15:00 · 인민 광장 주변"
                    android:textColor="@color/schedule_minimal_subtle" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/schedule_minimal_line" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <CheckBox
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/TriplineText.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.16 와이탄 야경"
                        android:textColor="@color/schedule_minimal_text" />

                    <TextView
                        style="@style/TriplineText.Badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                        android:background="@drawable/bg_tripline_secondary_action"
                        android:paddingStart="8dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="4dp"
                        android:text="검토 필요"
                        android:textColor="@color/schedule_minimal_subtle" />
                </LinearLayout>

                <TextView
                    style="@style/TriplineText.BodyCompact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="시간이 모호해서 편집 화면에서 위치와 순서를 다시 확인해 주세요."
                    android:textColor="@color/schedule_minimal_subtle" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            style="@style/TriplineText.Button"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_tripline_action"
            android:backgroundTint="@color/schedule_minimal_blue"
            android:gravity="center"
            android:text="선택한 일정 편집으로 가져가기"
            android:textColor="@color/white" />
    </LinearLayout>
</ScrollView>

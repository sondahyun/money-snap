<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_tripline_panel"
    android:orientation="vertical"
    android:paddingTop="16dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_tripline_pill"
        android:backgroundTint="@color/tripline_stroke_neutral" />

    <TextView
        android:id="@+id/buttonDeleteChecklistItem"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="삭제하기"
        android:textColor="@color/schedule_minimal_text"
        android:textSize="16sp"
        android:fontFamily="@font/pretendardmedium" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="20dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <ImageView
                android:id="@+id/buttonLoginBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="뒤로가기"
                android:padding="6dp"
                android:src="@drawable/ic_schedule_back"
                app:tint="@color/schedule_minimal_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="56dp"
                style="@style/TriplineText.ScreenTitle"
                android:text="이메일로 로그인"
                android:textColor="@color/schedule_minimal_text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="52dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TriplineText.Body"
                    android:text="이메일 주소"
                    android:textColor="@color/schedule_minimal_subtle" />

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/pretendardbold"
                    android:hint="abc@gmail.com"
                    android:paddingTop="0dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/schedule_minimal_text"
                    android:textColorHint="@color/tripline_text_hint"
                    android:textSize="18sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/tripline_stroke" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TriplineText.Body"
                    android:text="비밀번호"
                    android:textColor="@color/schedule_minimal_subtle" />

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/pretendardbold"
                    android:hint="영문, 숫자, 특수문자"
                    android:inputType="textPassword"
                    android:paddingTop="0dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/schedule_minimal_text"
                    android:textColorHint="@color/tripline_text_hint"
                    android:textSize="18sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/tripline_stroke" />
            </LinearLayout>

            <TextView
                android:id="@+id/buttonLoginSubmit"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="38dp"
                android:background="@drawable/bg_tripline_secondary_action_neutral"
                android:gravity="center"
                style="@style/TriplineText.Button"
                android:text="로그인"
                android:textColor="@color/schedule_minimal_text" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                style="@style/TriplineText.BodyCompact"
                android:text="비밀번호를 잊으셨나요?"
                android:textColor="@color/tripline_text_hint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/buttonLoginSignup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TriplineText.BodyCompact"
                    android:text="처음이신가요?"
                    android:textColor="@color/schedule_minimal_subtle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    style="@style/TriplineText.ActionLabel"
                    android:text="회원가입"
                    android:textColor="@color/schedule_minimal_blue" />
            </LinearLayout>

            <TextView
                android:id="@+id/buttonLoginGuest"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                style="@style/TriplineText.Button"
                android:text="가입 없이 둘러보기"
                android:textColor="@color/schedule_minimal_text" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

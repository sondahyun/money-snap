<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="28dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <ImageView
                android:id="@+id/buttonTripEditBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="뒤로가기"
                android:padding="6dp"
                android:src="@drawable/ic_schedule_back"
                app:tint="@color/schedule_minimal_text" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/schedule_minimal_blue_soft"
                    android:fontFamily="@font/pretendardsemibold"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:text="진행 예정"
                    android:textColor="@color/schedule_minimal_blue"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/pretendardmedium"
                    android:text="여행 기본 정보를 정리하면 보관함에서도 더 찾기 쉬워집니다."
                    android:textColor="@color/schedule_minimal_subtle"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/pretendardbold"
                android:lineSpacingExtra="4dp"
                android:text="여행의 기본 정보와\n표시 방식을 다듬어볼게요"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="23sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TriplineText.Body"
                        android:text="여행 제목"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/pretendardbold"
                        android:paddingTop="0dp"
                        android:paddingBottom="12dp"
                        android:text="상하이 여행"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="18sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tripline_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="34dp"
                        style="@style/TriplineText.Body"
                        android:text="국가 / 도시"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:fontFamily="@font/pretendardbold"
                                android:paddingTop="0dp"
                                android:paddingBottom="12dp"
                                android:text="중국"
                                android:textColor="@color/schedule_minimal_text"
                                android:textSize="18sp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/tripline_stroke" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:fontFamily="@font/pretendardbold"
                                android:paddingTop="0dp"
                                android:paddingBottom="12dp"
                                android:text="상하이"
                                android:textColor="@color/schedule_minimal_text"
                                android:textSize="18sp" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/tripline_stroke" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="34dp"
                        style="@style/TriplineText.Body"
                        android:text="여행 기간"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingTop="0dp"
                                android:paddingBottom="12dp"
                                android:text="2026.2.15"
                                android:textColor="@color/schedule_minimal_text"
                                android:textSize="18sp"
                                android:fontFamily="@font/pretendardbold" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/tripline_stroke" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingTop="0dp"
                                android:paddingBottom="12dp"
                                android:text="2026.2.18"
                                android:textColor="@color/schedule_minimal_text"
                                android:textSize="18sp"
                                android:fontFamily="@font/pretendardbold" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="@color/tripline_stroke" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="34dp"
                        style="@style/TriplineText.Body"
                        android:text="기준 통화"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <TextView
                        android:id="@+id/buttonTripEditSave"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/pretendardbold"
                        android:paddingTop="0dp"
                        android:paddingBottom="12dp"
                        android:text="KRW"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="18sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tripline_stroke" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        style="@style/TriplineText.Body"
                        android:text="여행 한 줄 소개"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/pretendardmedium"
                        android:gravity="center_vertical|start"
                        android:inputType="textCapSentences"
                        android:lines="1"
                        android:maxLines="1"
                        android:paddingTop="0dp"
                        android:paddingBottom="8dp"
                        android:ellipsize="end"
                        android:text="부모님과 함께, 동선은 여유롭게 잡고 대표 관광지는 꼭 가는 일정"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/tripline_stroke" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="38dp"
                        android:background="@drawable/bg_tripline_action"
                        android:backgroundTint="@color/schedule_minimal_blue"
                        android:fontFamily="@font/pretendardsemibold"
                        android:gravity="center"
                        android:text="수정 내용 저장"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_secondary_action"
                            android:fontFamily="@font/pretendardsemibold"
                            android:gravity="center"
                            android:text="여행 보관"
                            android:textColor="@color/schedule_minimal_text"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_tripline_secondary_action"
                            android:backgroundTint="@color/tripline_coral_soft"
                            android:fontFamily="@font/pretendardsemibold"
                            android:gravity="center"
                            android:text="여행 삭제"
                            android:textColor="@color/tripline_coral"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/schedule_minimal_surface"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="26dp"
    android:paddingEnd="24dp"
    android:paddingBottom="26dp"
    tools:ignore="HardcodedText">

    <TextView
        style="@style/TriplineText.ScreenTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="여행을 삭제할까요?"
        android:textColor="@color/schedule_minimal_text" />

    <TextView
        style="@style/TriplineText.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="삭제하면 보관함과 일정 화면에서 이 여행이 보이지 않아요. 연결된 일정, 숙소, 항공편, 지출도 함께 숨겨집니다."
        android:textColor="@color/schedule_minimal_subtle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/buttonTripDeleteCancel"
            style="@style/TriplineText.Button"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tripline_secondary_action"
            android:gravity="center"
            android:text="취소"
            android:textColor="@color/schedule_minimal_text" />

        <TextView
            android:id="@+id/buttonTripDeleteConfirm"
            style="@style/TriplineText.Button"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tripline_action"
            android:backgroundTint="@color/tripline_coral"
            android:gravity="center"
            android:text="삭제"
            android:textColor="@color/white" />
    </LinearLayout>
</LinearLayout>

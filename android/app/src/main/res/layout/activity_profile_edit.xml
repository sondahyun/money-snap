<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/buttonProfileSave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="28dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/buttonProfileEditBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="뒤로가기"
                    android:padding="6dp"
                    android:src="@drawable/ic_schedule_back"
                    app:tint="@color/schedule_minimal_text" />

                <TextView
                    style="@style/TriplineText.NavTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="프로필 수정"
                    android:textColor="@color/schedule_minimal_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="34dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/tripline_surface_neutral">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/pretendardbold"
                        android:gravity="center"
                        android:text="손"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="28sp" />

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="end|bottom"
                        android:background="@drawable/bg_tripline_pill"
                        android:backgroundTint="@color/schedule_minimal_blue"
                        android:fontFamily="@font/pretendardbold"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/white"
                        android:textSize="18sp" />
                </FrameLayout>

                <TextView
                    style="@style/TriplineText.BodyCompact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="프로필 사진은 선택 사항이에요"
                    android:textColor="@color/schedule_minimal_subtle" />
            </LinearLayout>

            <TextView
                style="@style/TriplineText.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:text="닉네임"
                android:textColor="@color/schedule_minimal_subtle" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@android:color/transparent"
                android:fontFamily="@font/pretendardbold"
                android:inputType="text"
                android:paddingTop="0dp"
                android:paddingBottom="12dp"
                android:text="손다현"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/tripline_stroke" />

            <TextView
                style="@style/TriplineText.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="이메일"
                android:textColor="@color/schedule_minimal_subtle" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/pretendardbold"
                android:paddingBottom="12dp"
                android:text="tripline@example.com"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="18sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/tripline_stroke" />

            <TextView
                style="@style/TriplineText.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="이메일은 로그인 계정 기준이라 여기서는 수정하지 않아요."
                android:textColor="@color/schedule_minimal_subtle" />
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/buttonProfileSave"
        style="@style/TriplineText.Button"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_tripline_action"
        android:gravity="center"
        android:text="저장"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/tripline_surface_neutral"
                    android:paddingStart="12dp"
                    android:paddingTop="7dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="7dp"
                    android:text="EXPENSE"
                    android:textColor="@color/tripline_text_secondary" />

                <TextView
                    style="@style/TriplineText.ScreenTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="지출 관리"
                    android:textColor="@color/schedule_minimal_text" />

                <TextView
                    style="@style/TriplineText.BodyCompact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="이번 여행에서 실제로 나간 금액을 장소별 또는 상위 카테고리별로 확인할 수 있어요."
                    android:textColor="@color/schedule_minimal_subtle" />
            </LinearLayout>

            <TextView
                android:id="@+id/buttonFundsAddExpense"
                style="@style/TriplineText.Button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tripline_action"
                android:backgroundTint="@color/schedule_minimal_blue"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="+ 지출 추가"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기록 건수"
                    android:textColor="@color/schedule_minimal_subtle" />

                <TextView
                    style="@style/TriplineText.Amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="12건"
                    android:textColor="@color/tripline_text_primary" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="34dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@color/tripline_stroke_neutral" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.Meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="총 지출"
                    android:textColor="@color/schedule_minimal_subtle" />

                <TextView
                    style="@style/TriplineText.Amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="₩321,400"
                    android:textColor="@color/tripline_amount_blue" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@color/tripline_stroke_neutral" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonFundsPlaceTab"
                style="@style/TriplineText.ActionLabel"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="@color/schedule_minimal_blue"
                android:gravity="center"
                android:text="장소별"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/buttonFundsCategoryTab"
                style="@style/TriplineText.ActionLabel"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_secondary_action_neutral"
                android:gravity="center"
                android:text="상위 카테고리별"
                android:textColor="@color/tripline_text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/textFundsListTitle"
            style="@style/TriplineText.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="장소별 지출"
            android:textColor="@color/schedule_minimal_text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rowFundsPlaceWaitan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textFundsRow1Title"
                        style="@style/TriplineText.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="와이탄"
                        android:textColor="@color/schedule_minimal_text" />

                    <TextView
                        android:id="@+id/textFundsRow1Meta"
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="지출 4건"
                        android:textColor="@color/schedule_minimal_subtle" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textFundsRow1Amount"
                    style="@style/TriplineText.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₩132,800"
                    android:textColor="@color/tripline_amount_blue" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/tripline_stroke_neutral" />

            <LinearLayout
                android:id="@+id/rowFundsPlaceExchange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textFundsRow2Title"
                        style="@style/TriplineText.CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="환전"
                        android:textColor="@color/schedule_minimal_text" />

                    <TextView
                        android:id="@+id/textFundsRow2Meta"
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="지출 1건"
                        android:textColor="@color/schedule_minimal_subtle" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textFundsRow2Amount"
                    style="@style/TriplineText.CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₩200,000"
                    android:textColor="@color/tripline_amount_blue" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>

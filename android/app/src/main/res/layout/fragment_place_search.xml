            android:src="@drawable/ic_tripline_current_location"
            android:tint="@color/tripline_navy" />

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_tripline_icon_button_neutral"
            android:contentDescription="동선 보기"
            android:padding="11dp"
            android:src="@drawable/ic_tripline_route"
            android:tint="@color/tripline_navy" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/place_search_sheet"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_place_search_sheet"
        android:orientation="vertical"
        android:paddingTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/place_search_sheet_guideline">

        <View
            android:layout_width="44dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_tripline_pill"
            android:backgroundTint="@color/tripline_stroke_neutral" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">


            android:textColor="@color/white"
            android:textSize="13sp" />

        <TextView
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="54dp"
            android:layout_marginTop="250dp"

                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="14dp">

                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_tripline_surface_soft">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_tripline_food"
                            android:tint="#FF6B6B" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TriplineText.CardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="란팅찬팅"
                            android:textColor="@color/tripline_text_primary" />

                        <TextView
                            style="@style/TriplineText.BodyCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="2019 미슐랭 빕구르망에 선정된 중국 가정식 레스토랑"
                            android:textColor="@color/tripline_text_secondary" />

                        <TextView
                            style="@style/TriplineText.BodyCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="★ 4.3(55) · 저장 5272"
                            android:textColor="@color/tripline_text_secondary" />

                        <TextView
                            style="@style/TriplineText.BodyCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="음식점"
                            android:textColor="@color/tripline_text_hint" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/buttonPlaceSelect2"
                        android:layout_width="62dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_tripline_selection_action"
                        android:gravity="center"
                        style="@style/TriplineText.ActionLabel"
                        android:text="선택"
                        android:textColor="@color/tripline_text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="6dp"
                    android:paddingBottom="18dp">

                    <FrameLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_tripline_surface_soft">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_tripline_flag"
                            android:tint="#8B5CF6" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/TriplineText.CardTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="레고"
                            android:textColor="@color/tripline_text_primary" />

                        <TextView
                            style="@style/TriplineText.BodyCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="레고로 재현한 세계 각국의 랜드마크가 눈길을 사로잡는 곳"
                            android:textColor="@color/tripline_text_secondary" />

                        <TextView
                            style="@style/TriplineText.BodyCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="★ 4.0(67) · 저장 2642"
                            android:textColor="@color/tripline_text_secondary" />

                        <TextView
                            style="@style/TriplineText.BodyCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="쇼핑 · 인민 광장 주변"
                            android:textColor="@color/tripline_text_hint" />

                            android:textColor="@color/tripline_text_secondary" />

                        <TextView
                            style="@style/TriplineText.BodyCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="★ 4.1(499) · 저장 22962"
                            android:textColor="@color/tripline_text_secondary" />

                        <TextView
                            style="@style/TriplineText.BodyCompact"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="음식점 · 인민 광장 주변"
                            android:textColor="@color/tripline_text_hint" />

            android:backgroundTint="#8B5CF6"
            android:fontFamily="@font/pretendardbold"
            android:gravity="center"
            android:text="4"
            android:textColor="@color/white"
            android:textSize="13sp" />

        <TextView
            android:layout_width="32dp"
            android:layout_height="32dp"

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="14dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/buttonEditBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_schedule_icon_button">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_schedule_back"
                        app:tint="@color/schedule_minimal_text" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TriplineText.NavTitle"
                        android:text="후쿠오카, 도쿄, 오사카 여행"
                        android:textColor="@color/schedule_minimal_text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        style="@style/TriplineText.Meta"
                        android:text="2026.5.7 - 5.11 · 4박 5일"
                        android:textColor="@color/schedule_minimal_subtle" />
                </LinearLayout>

                <TextView
                    android:id="@+id/buttonEditDone"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    style="@style/TriplineText.Button"
                    android:text="완료"
                    android:textColor="@color/schedule_minimal_blue" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_schedule_map_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="132dp">

                        <View
                            android:layout_width="200dp"
                            android:layout_height="4dp"
                            android:alpha="0.55"
                            android:background="@color/schedule_minimal_blue"
                            android:rotation="-14"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintHorizontal_bias="0.48"
                            app:layout_constraintVertical_bias="0.48" />

                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/tripline_marker_blue"
                            android:fontFamily="@font/pretendardbold"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintHorizontal_bias="0.11"
                            app:layout_constraintVertical_bias="0.70" />

                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/tripline_marker_teal"
                            android:fontFamily="@font/pretendardbold"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintHorizontal_bias="0.67"
                            app:layout_constraintVertical_bias="0.46" />

                        <TextView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/tripline_marker_coral"
                            android:fontFamily="@font/pretendardbold"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintHorizontal_bias="0.90"
                            app:layout_constraintVertical_bias="0.18" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_schedule_distance_chip"
                                android:paddingStart="10dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="8dp"
                                style="@style/TriplineText.Meta"
                                android:text="도보 11분"
                                android:textColor="@color/schedule_minimal_text" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_schedule_distance_chip"
                                android:paddingStart="10dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="8dp"
                                style="@style/TriplineText.Meta"
                                android:text="차량 4분"
                                android:textColor="@color/schedule_minimal_text" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_schedule_distance_chip"
                                android:paddingStart="10dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="8dp"
                                style="@style/TriplineText.Meta"
                                android:text="1.3km"
                                android:textColor="@color/schedule_minimal_text" />
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="@style/TriplineText.SectionTitle"
                    android:text="day 일정"
                    android:textColor="@color/schedule_minimal_text" />

                <TextView
                    android:id="@+id/buttonImportOcr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/TriplineText.ActionLabel"
                    android:text="OCR 가져오기"
                    android:textColor="@color/schedule_minimal_blue" />
            </LinearLayout>

            <View
                android:layout_width="54dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="@color/schedule_minimal_line" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/TriplineText.DayTitle"
                                    android:text="day 1"
                                    android:textColor="@color/schedule_minimal_text" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    style="@style/TriplineText.Body"
                                    android:text="5.7/목"
                                    android:textColor="@color/schedule_minimal_subtle" />

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_marginStart="6dp"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_schedule_chevron_down"
                                    app:tint="@color/schedule_minimal_subtle" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_tripline_sort" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                style="@style/TriplineText.ActionLabel"
                                android:text="거리순 재정렬"
                                android:textColor="@color/schedule_minimal_blue" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="16dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_tripline_circle_outline" />

                            <View
                                android:layout_width="2dp"
                                android:layout_height="68dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_schedule_timeline_line" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_tripline_circle_outline" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:cardBackgroundColor="@color/schedule_minimal_surface"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/schedule_minimal_line"
                                app:strokeWidth="1dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:padding="16dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            style="@style/TriplineText.NavTitle"
                                            android:text="후쿠오카 공항"
                                            android:textColor="@color/schedule_minimal_text" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="6dp"
                                            style="@style/TriplineText.BodyCompact"
                                            android:text="교통시설 · 하카타 주변"
                                            android:textColor="@color/schedule_minimal_subtle" />
                                    </LinearLayout>

                                    <ImageView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:contentDescription="@null"
                                        android:src="@drawable/ic_tripline_drag_handle" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_schedule_distance_chip"
                                android:paddingStart="12dp"
                                android:paddingTop="8dp"
                                android:paddingEnd="12dp"
                                android:paddingBottom="8dp"
                                style="@style/TriplineText.Meta"
                                android:text="5.1km · 차량 18분 · 지하철 12분"
                                android:textColor="@color/schedule_minimal_text" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:cardBackgroundColor="@color/schedule_minimal_surface"
                                    app:cardCornerRadius="20dp"
                                    app:cardElevation="0dp"
                                    app:strokeColor="@color/schedule_minimal_line"
                                    app:strokeWidth="1dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal"
                                        android:padding="16dp">

                                        <LinearLayout
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            style="@style/TriplineText.NavTitle"
                                            android:text="캐널시티 하카타"
                                            android:textColor="@color/schedule_minimal_text" />

                                            <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_marginTop="6dp"
                                                style="@style/TriplineText.BodyCompact"
                                                android:text="쇼핑몰 · 하카타 주변"
                                                android:textColor="@color/schedule_minimal_subtle" />
                                        </LinearLayout>

                                        <ImageView
                                            android:layout_width="18dp"
                                            android:layout_height="18dp"
                                            android:contentDescription="@null"
                                            android:src="@drawable/ic_tripline_drag_handle" />
                                    </LinearLayout>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_tripline_secondary_action"
                        android:gravity="center"
                        style="@style/TriplineText.Button"
                        android:text="day 전체 선택"
                        android:textColor="@color/schedule_minimal_text" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    style="@style/TriplineText.DayTitle"
                                    android:text="day 2"
                                    android:textColor="@color/schedule_minimal_text" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    style="@style/TriplineText.Body"
                                    android:text="5.8/금"
                                    android:textColor="@color/schedule_minimal_subtle" />
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TriplineText.ActionLabel"
                            android:text="편집 중"
                            android:textColor="@color/schedule_minimal_blue" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="20dp"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="16dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_tripline_circle_outline" />

                            <View
                                android:layout_width="2dp"
                                android:layout_height="68dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_schedule_timeline_line" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="10dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_tripline_circle_outline" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:cardBackgroundColor="@color/schedule_minimal_surface"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:strokeColor="@color/schedule_minimal_line"
                                app:strokeWidth="1dp">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal"
                                    android:padding="16dp">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            style="@style/TriplineText.NavTitle"
                                            android:text="도쿄역"
                                            android:textColor="@color/schedule_minimal_text" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="6dp"
                                            style="@style/TriplineText.BodyCompact"
                                                android:text="교통시설 · 마루노우치 주변"
                                            android:textColor="@color/schedule_minimal_subtle" />
                                    </LinearLayout>

                                    <ImageView
                                        android:layout_width="18dp"
                                        android:layout_height="18dp"
                                        android:contentDescription="@null"
                                        android:src="@drawable/ic_tripline_drag_handle" />
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_schedule_distance_chip"
                                    android:paddingStart="10dp"
                                    android:paddingTop="8dp"
                                    android:paddingEnd="10dp"
                                    android:paddingBottom="8dp"
                                    style="@style/TriplineText.Meta"
                                    android:text="1.2km"
                                    android:textColor="@color/schedule_minimal_text" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_schedule_distance_chip"
                                    android:paddingStart="10dp"
                                    android:paddingTop="8dp"
                                    android:paddingEnd="10dp"
                                    android:paddingBottom="8dp"
                                    style="@style/TriplineText.Meta"
                                    android:text="도보 6분"
                                    android:textColor="@color/schedule_minimal_text" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:cardBackgroundColor="@color/schedule_minimal_surface"
                                    app:cardCornerRadius="20dp"
                                    app:cardElevation="0dp"
                                    app:strokeColor="@color/schedule_minimal_line"
                                    app:strokeWidth="1dp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal"
                                        android:padding="16dp">

                                        <LinearLayout
                                            android:layout_width="0dp"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1"
                                            android:orientation="vertical">

                                            <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                style="@style/TriplineText.CardTitle"
                                                android:text="오사카성"
                                                android:textColor="@color/schedule_minimal_text" />

                                            <TextView
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_marginTop="6dp"
                                                style="@style/TriplineText.BodyCompact"
                                                android:text="관광명소 · 오사카성 공원"
                                                android:textColor="@color/schedule_minimal_subtle" />
                                        </LinearLayout>

                                        <ImageView
                                            android:layout_width="18dp"
                                            android:layout_height="18dp"
                                            android:contentDescription="@null"
                                            android:src="@drawable/ic_tripline_drag_handle" />
                                    </LinearLayout>
                                </com.google.android.material.card.MaterialCardView>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

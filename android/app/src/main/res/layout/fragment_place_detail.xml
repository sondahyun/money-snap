<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/buttonPlaceDetailBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_tripline_icon_button_neutral"
                android:contentDescription="뒤로가기"
                android:padding="8dp"
                android:src="@drawable/ic_tripline_back" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_tripline_icon_button_neutral"
                android:contentDescription="지도"
                android:padding="8dp"
                android:src="@drawable/ic_map"
                android:tint="@color/schedule_minimal_text" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_tripline_icon_button_neutral"
                android:contentDescription="더보기"
                android:padding="8dp"
                android:src="@drawable/ic_tripline_more_horizontal"
                android:tint="@color/schedule_minimal_text" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.ScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="남상만두 예원 점"
            android:textColor="@color/schedule_minimal_text"
            android:textSize="22sp" />

        <TextView
            style="@style/TriplineText.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="南翔馒头店 豫园店"
            android:textColor="@color/schedule_minimal_subtle" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TriplineText.CardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★★★★☆"
                android:textColor="#F7BE18" />

            <TextView
                style="@style/TriplineText.CardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="110"
                android:textColor="@color/schedule_minimal_text" />

            <TextView
                style="@style/TriplineText.CardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:text="♥ 8,518"
                android:textColor="#EB557A" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.CardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="📍 인민 광장 주변"
            android:textColor="@color/schedule_minimal_text" />

        <TextView
            android:id="@+id/buttonPlaceReserve"
            style="@style/TriplineText.Button"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_tripline_action"
            android:backgroundTint="@color/schedule_minimal_blue"
            android:gravity="center"
            android:minWidth="108dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="일정에 추가"
            android:textColor="@color/white" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_schedule_map_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                style="@style/TriplineText.CardTitle"
                android:text="대표 사진"
                android:textColor="@color/schedule_minimal_subtle" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="#7A8B9A9A"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="1 / 110"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                style="@style/TriplineText.BodyCompact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="저장하기"
                android:textColor="@color/schedule_minimal_subtle" />

            <TextView
                android:id="@+id/buttonAddPlaceToSchedule"
                style="@style/TriplineText.BodyCompact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="일정추가"
                android:textColor="@color/schedule_minimal_text"
                android:textStyle="bold" />

            <TextView
                style="@style/TriplineText.BodyCompact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="상세정보"
                android:textColor="@color/schedule_minimal_subtle" />

            <TextView
                style="@style/TriplineText.BodyCompact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="공유하기"
                android:textColor="@color/schedule_minimal_subtle" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@color/schedule_minimal_line" />

        <TextView
            style="@style/TriplineText.ScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="100년이 넘는 전통을 간직한 남상만두의 원조로 유명한 음식점"
            android:textColor="@color/schedule_minimal_text"
            android:textSize="18sp" />

        <TextView
            style="@style/TriplineText.CardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="대표메뉴"
            android:textColor="@color/schedule_minimal_text" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="136dp"
                    android:layout_height="112dp"
                    android:background="@drawable/bg_schedule_map_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        style="@style/TriplineText.BodyCompact"
                        android:text="샤오롱바오"
                        android:textColor="@color/schedule_minimal_subtle" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="136dp"
                    android:layout_height="112dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_schedule_map_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        style="@style/TriplineText.BodyCompact"
                        android:text="게살 만두"
                        android:textColor="@color/schedule_minimal_subtle" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="136dp"
                    android:layout_height="112dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_schedule_map_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        style="@style/TriplineText.BodyCompact"
                        android:text="새우 만두"
                        android:textColor="@color/schedule_minimal_subtle" />
                </FrameLayout>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    android:paddingStart="22dp"
    android:paddingTop="24dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp"
    tools:ignore="HardcodedText">

    <ImageView
        android:id="@+id/buttonTripStyleBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="뒤로가기"
        android:padding="6dp"
        android:src="@drawable/ic_schedule_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/schedule_minimal_text" />

    <TextView
        android:id="@+id/textTripStyleTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:fontFamily="@font/pretendardbold"
        android:lineSpacingExtra="2dp"
        android:text="어떤 스타일의\n여행을 할 계획인가요?"
        android:textColor="@color/schedule_minimal_text"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonTripStyleBack" />

    <LinearLayout
        android:id="@+id/tripStyleContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textTripStyleTitle">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TriplineText.SectionTitle"
            android:text="누구와"
            android:textColor="@color/schedule_minimal_text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="혼자"
                android:textColor="@color/tripline_text_hint"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="친구와"
                android:textColor="@color/tripline_text_hint"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="연인과"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="아이와"
                android:textColor="@color/tripline_text_hint"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="부모님과"
                android:textColor="@color/tripline_text_hint"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="기타"
                android:textColor="@color/tripline_text_hint"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            style="@style/TriplineText.SectionTitle"
            android:text="여행 스타일"
            android:textColor="@color/schedule_minimal_text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="체험·액티비티"
                android:textColor="@color/tripline_text_hint"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="유명 관광지는 필수"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="여유롭게 힐링"
                android:textColor="@color/tripline_text_hint"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_secondary_action"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="문화·예술·역사"
                android:textColor="@color/tripline_text_hint"
                android:textSize="13sp"
                android:fontFamily="@font/pretendardbold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/buttonTripStyleDone"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_tripline_action"
        android:fontFamily="@font/pretendardbold"
        android:gravity="center"
        android:text="완료"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/buttonTripStyleSkip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/buttonTripStyleSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pretendardbold"
        android:padding="8dp"
        android:text="다음에 하기"
        android:textColor="@color/schedule_minimal_subtle"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:id="@+id/lodgingSearchHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/buttonLodgingSearchBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="뒤로가기"
            android:padding="6dp"
            android:src="@drawable/ic_schedule_back"
            app:tint="@color/schedule_minimal_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:fontFamily="@font/pretendardbold"
            android:text="숙소명 검색"
            android:textColor="@color/tripline_text_hint"
            android:textSize="17sp" />

        <ImageView
            android:id="@+id/buttonLodgingSearchIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="검색"
            android:padding="6dp"
            android:src="@drawable/ic_search_modern"
            app:tint="@color/schedule_minimal_text" />
    </LinearLayout>

    <View
        android:id="@+id/lodgingHeaderDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/schedule_minimal_line"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lodgingSearchHeader" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lodgingHeaderDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
                android:paddingTop="18dp"
            android:paddingEnd="22dp">

            <LinearLayout
                android:id="@+id/buttonLodgingManualAdd"
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/pretendardbold"
                        android:text="나만의 장소 추가"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/pretendardmedium"
                        android:lineSpacingExtra="3dp"
                        android:text="에어비앤비, 게스트하우스 등\n찾는 장소가 없다면 직접 등록해보세요."
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/schedule_minimal_blue" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="14dp"
                android:background="@color/schedule_minimal_line" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/pretendardbold"
                android:text="인기 숙소"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/pretendardbold"
                android:text="후쿠오카"
                android:textColor="@color/schedule_minimal_text"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/buttonLodgingSelect1"
                style="@style/TriplineText.Body"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/tripline_marker_blue"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center"
                    android:text="호텔"
                    android:textColor="@color/white"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/pretendardbold"
                        android:maxLines="1"
                        android:text="호텔 오리엔탈 익스프레스 후쿠오카 나카스 카와바타"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/pretendardmedium"
                        android:text="3성급 · 하카타"
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_tripline_secondary_action_neutral"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center"
                    android:text="선택"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonLodgingSelect2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/tripline_marker_teal"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center"
                    android:text="9h"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/pretendardbold"
                        android:maxLines="1"
                        android:text="나인아워스 하카타 스테이션"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/pretendardmedium"
                        android:text="2성급 · 하카타"
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_tripline_secondary_action_neutral"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center"
                    android:text="선택"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonLodgingSelect3"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/tripline_marker_coral"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center"
                    android:text="WB"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/pretendardbold"
                        android:maxLines="1"
                        android:text="위베이스 하카타 호스텔"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/pretendardmedium"
                        android:text="2성급 · 하카타"
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_tripline_secondary_action_neutral"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center"
                    android:text="선택"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/buttonLodgingSelect4"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/tripline_marker_amber"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center"
                    android:text="MY"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/pretendardbold"
                        android:maxLines="1"
                        android:text="호텔 마이스테이 후쿠오카 텐진"
                        android:textColor="@color/schedule_minimal_text"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/pretendardmedium"
                        android:text="3성급 · 텐진"
                        android:textColor="@color/schedule_minimal_subtle"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_tripline_secondary_action_neutral"
                    android:fontFamily="@font/pretendardbold"
                    android:gravity="center"
                    android:text="선택"
                    android:textColor="@color/schedule_minimal_text"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/lodgingBottomNav"
        android:layout_width="0dp"
        android:layout_height="62dp"
        android:background="@color/white"
        android:gravity="center"
        android:visibility="gone"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="여행 홈" android:textColor="@color/schedule_minimal_subtle" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="보관함" android:textColor="@color/schedule_minimal_subtle" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="일정" android:textColor="@color/schedule_minimal_text" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="가계부" android:textColor="@color/schedule_minimal_subtle" android:textSize="12sp" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="마이" android:textColor="@color/schedule_minimal_subtle" android:textSize="12sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

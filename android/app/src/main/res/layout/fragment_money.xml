<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tripline_background">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/buttonExchangeBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_tripline_icon_button_neutral"
                    android:contentDescription="뒤로가기"
                    android:padding="8dp"
                    android:src="@drawable/ic_tripline_back" />

                <TextView
                    style="@style/TriplineText.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_tripline_tag"
                    android:paddingStart="12dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="6dp"
                    android:text="FX"
                    android:textColor="@color/tripline_navy" />
            </LinearLayout>

            <TextView
                android:id="@+id/todayExchange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                style="@style/TriplineText.ScreenTitle"
                android:text="환율 참고"
                android:textColor="@color/tripline_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                style="@style/TriplineText.BodyCompact"
                android:text="선택한 날짜 기준 환율과 전 영업일 대비 흐름을 참고할 수 있어요."
                android:textColor="@color/tripline_text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/selected_date"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_input"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                style="@style/TriplineText.Input"
                android:text="날짜를 선택하세요"
                android:textColor="@color/tripline_text_primary" />

            <Button
                android:id="@+id/date_picker_button"
                android:layout_width="84dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tripline_action"
                style="@style/TriplineText.Button"
                android:text="선택"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/TriplineText.CardTitle"
                android:text="환율 리스트"
                android:textColor="@color/tripline_text_primary" />

            <TextView
                android:id="@+id/exchange_list_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                style="@style/TriplineText.BodyCompact"
                android:text="환전이나 현지 결제 전에 비교해볼 수 있는 기준 환율 데이터입니다."
                android:textColor="@color/tripline_text_secondary" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/exchangeRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="4dp"
                tools:listitem="@layout/item_exchange_rate" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

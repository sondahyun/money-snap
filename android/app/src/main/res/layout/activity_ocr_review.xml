<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/schedule_minimal_bg"
    tools:ignore="HardcodedText">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/buttonOcrReviewConfirm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="28dp"
            android:paddingEnd="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/buttonOcrReviewBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="뒤로가기"
                    android:padding="6dp"
                    android:src="@drawable/ic_schedule_back"
                    app:tint="@color/schedule_minimal_text" />

                <TextView
                    style="@style/TriplineText.NavTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="OCR 검수"
                    android:textColor="@color/schedule_minimal_text" />
            </LinearLayout>

            <TextView
                style="@style/TriplineText.ScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="읽은 일정 중 넣을 항목만 고를게요"
                android:textColor="@color/schedule_minimal_text" />

            <TextView
                style="@style/TriplineText.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="후보를 수정하거나 제외한 뒤 현재 여행의 일정 편집 화면으로 넘깁니다."
                android:textColor="@color/schedule_minimal_subtle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/TriplineText.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tripline_pill"
                    android:backgroundTint="@color/schedule_minimal_blue_soft"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="선택 2개"
                    android:textColor="@color/schedule_minimal_blue" />

                <TextView
                    style="@style/TriplineText.Badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_tripline_secondary_action"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:text="검토 필요 1개"
                    android:textColor="@color/schedule_minimal_subtle" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/schedule_minimal_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/schedule_minimal_line"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <CheckBox
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="항공편 후보"
                        android:textColor="@color/schedule_minimal_blue" />

                    <TextView
                        style="@style/TriplineText.CardTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="GMP 12:00 - SHA 13:05"
                        android:textColor="@color/schedule_minimal_text" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="중국동방항공 · MU512 · day1 2.15/일"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/buttonOcrCandidateFlightEdit"
                            style="@style/TriplineText.ActionLabel"
                            android:layout_width="64dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_tripline_secondary_action_neutral"
                            android:gravity="center"
                            android:text="수정"
                            android:textColor="@color/schedule_minimal_text" />

                        <TextView
                            android:id="@+id/buttonOcrCandidateFlightApprove"
                            style="@style/TriplineText.ActionLabel"
                            android:layout_width="78dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/schedule_minimal_blue"
                            android:gravity="center"
                            android:text="승인 유지"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/schedule_minimal_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/schedule_minimal_line"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <CheckBox
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="숙소 후보"
                        android:textColor="@color/schedule_minimal_blue" />

                    <TextView
                        style="@style/TriplineText.CardTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="캄파닐레 호텔 상하이 번드"
                        android:textColor="@color/schedule_minimal_text" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="체크인 day1 15:00 · 체크아웃 day4"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/buttonOcrCandidateLodgingEdit"
                            style="@style/TriplineText.ActionLabel"
                            android:layout_width="64dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_tripline_secondary_action_neutral"
                            android:gravity="center"
                            android:text="수정"
                            android:textColor="@color/schedule_minimal_text" />

                        <TextView
                            android:id="@+id/buttonOcrCandidateLodgingApprove"
                            style="@style/TriplineText.ActionLabel"
                            android:layout_width="78dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_tripline_pill"
                            android:backgroundTint="@color/schedule_minimal_blue"
                            android:gravity="center"
                            android:text="승인 유지"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/tripline_surface_neutral"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/schedule_minimal_line"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <CheckBox
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:text="장소 후보"
                        android:textColor="@color/schedule_minimal_subtle" />

                    <TextView
                        style="@style/TriplineText.CardTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="와이탄 야경"
                        android:textColor="@color/schedule_minimal_text" />

                    <TextView
                        style="@style/TriplineText.BodyCompact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="날짜와 시간이 모호해서 제외 상태로 두었어요."
                        android:textColor="@color/schedule_minimal_subtle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/buttonOcrCandidatePlaceEdit"
                            style="@style/TriplineText.ActionLabel"
                            android:layout_width="64dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_tripline_secondary_action_neutral"
                            android:gravity="center"
                            android:text="수정"
                            android:textColor="@color/schedule_minimal_text" />

                        <TextView
                            android:id="@+id/buttonOcrCandidatePlaceReject"
                            style="@style/TriplineText.ActionLabel"
                            android:layout_width="78dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_tripline_secondary_action"
                            android:gravity="center"
                            android:text="거절 유지"
                            android:textColor="@color/schedule_minimal_subtle" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/buttonOcrReviewConfirm"
        style="@style/TriplineText.Button"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_tripline_action"
        android:gravity="center"
        android:text="선택한 일정 반영하기"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>

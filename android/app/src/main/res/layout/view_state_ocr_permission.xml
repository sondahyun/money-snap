<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <ImageView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_tripline_icon_button"
        android:contentDescription="권한 안내"
        android:padding="10dp"
        android:src="@drawable/ic_tripline_book" />

    <TextView
        style="@style/TriplineText.SectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="카메라 접근이 필요해요"
        android:textColor="@color/schedule_minimal_text" />

    <TextView
        style="@style/TriplineText.BodyCompact"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="촬영으로 가져오려면 카메라 권한을 켜 주세요. 지금은 앨범에서 일정표를 불러올 수도 있어요."
        android:textColor="@color/schedule_minimal_subtle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            style="@style/TriplineText.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tripline_action"
            android:backgroundTint="@color/schedule_minimal_blue"
            android:gravity="center"
            android:text="설정 열기"
            android:textColor="@color/white" />

        <TextView
            style="@style/TriplineText.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tripline_secondary_action"
            android:gravity="center"
            android:text="앨범에서 가져오기"
            android:textColor="@color/schedule_minimal_text" />
    </LinearLayout>
</LinearLayout>

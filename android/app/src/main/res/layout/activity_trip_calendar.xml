    <LinearLayout
        android:id="@+id/tripCalendarBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_place_search_sheet"
        android:elevation="12dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="2dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:behavior_draggable="true"
        app:behavior_hideable="false"
        app:behavior_peekHeight="220dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="18dp">

            <View
                android:layout_width="56dp"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_tripline_sheet_handle" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TriplineText.DayTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2월 16일 월요일"
                    android:textColor="@color/tripline_text_primary" />

                <TextView
                    style="@style/TriplineText.BodyCompact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="이 여행에 기록한 지출만 아래에서 자세히 확인해요."
                    android:textColor="@color/tripline_text_secondary" />
            </LinearLayout>

            <TextView
                android:id="@+id/buttonTripCalendarAddExpense"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_tripline_action"
                android:fontFamily="@font/pretendardsemibold"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="지출 추가"
                android:textColor="@color/white"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            style="@style/TriplineText.SectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="이 여행 지출 내역"
            android:textColor="@color/tripline_text_primary" />

        <TextView
            style="@style/TriplineText.Meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="3건 · CNY 1,148 · ₩218,120"
            android:textColor="@color/tripline_text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonTripCalendarPlaceTab"
                style="@style/TriplineText.ActionLabel"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:background="@drawable/bg_tripline_pill"
                android:backgroundTint="@color/schedule_minimal_blue"

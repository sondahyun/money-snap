                        android:text="2"
                        android:textColor="@color/tripline_text_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/tripline_text_primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:gravity="center"

                            android:layout_marginTop="2dp"
                            android:text="₩0"
                            android:textColor="@color/tripline_text_secondary"
                            android:textSize="8sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
